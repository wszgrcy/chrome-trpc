{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": "../../",
    "lib": [
      "ES2020",
      "dom"
    ],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "chrome-types"
    ],
    "paths": {
      "@cyia/chrome-trpc/server": [
        "../../server/index.ts"
      ],
      "@cyia/chrome-trpc/client": [
        "../../client/index.ts"
      ],
    }
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}