{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "name": "Hello Extensions",
  "description": "Base Level Extension",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["*://*/*"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
